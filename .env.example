# Copy to .env and fill in. Never commit .env (already in .gitignore).

# --- OpenAI (used for B2B profile synthesis + branch outlook) ---
OPENAI_API_KEY=sk-...

# --- Gemini (used for fast home + impressum + product extraction) ---
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Optional: which provider for catalog/structured extraction in full mode
LLM_PROVIDER=gemini/gemini-2.5-flash
# Model for fast extractor
FAST_MODEL=gemini-2.5-flash-lite
# Model for B2B profile + branch outlook (full mode)
SYNTHESIS_MODEL=openai/gpt-4o
BRANCH_OUTLOOK_MODEL=gpt-4o

# --- Tavily (competitor + news search in full mode and fast mode enrichment) ---
TAVILY_API_KEY=tvly-...

# --- SectorBench Public Data API (branch classification + outlook) ---
# Bearer token issued via the SectorBench operator CLI.
SECTORBENCH_API_TOKEN=sbk_...
# SECTORBENCH_BASE_URL=https://sectorbench.theaiwhisperer.cloud/api/v1
